# ============================================
# PassPilot — Environment Variables
# ============================================
# Copy this file to .env.local and fill in real values.
# All NEXT_PUBLIC_* vars are exposed to the client bundle.

# ---- AI (optional but unlocks premium features) ----
# Free Gemini key: https://aistudio.google.com/apikey
# Free tier: 1500 req/day with gemini-flash-latest
# If missing: "Why wrong? (AI)" button won't appear; official explanations still work.
NEXT_PUBLIC_GEMINI_API_KEY=

# ---- Native IAP (RevenueCat) — required for iOS/Android submission ----
# Sign up at https://app.revenuecat.com (free up to $2,500 MTR).
# Create iOS app + Android app with bundle/package com.galtrix.passpilot,
# then copy the PUBLIC SDK keys (NOT the secret key). Full setup: APPLE-READY.md
# Missing these keys => iOS shows "upgrade coming soon" placeholder (still Apple-safe).
NEXT_PUBLIC_REVENUECAT_IOS_KEY=
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY=

# ---- Lemon Squeezy checkout URLs (optional overrides) ----
# If set, these override the defaults in lib/licensing.ts.
# Useful for adding new tiers (Weekly / Annual / Lifetime) without code changes.
# Leave blank to use the defaults already live.
# NEXT_PUBLIC_LS_PRO_AZ900=
# NEXT_PUBLIC_LS_PRO_AWS_CCP=
# NEXT_PUBLIC_LS_PRO_MS900=
# NEXT_PUBLIC_LS_MULTI=
# NEXT_PUBLIC_LS_WEEKLY=
# NEXT_PUBLIC_LS_ANNUAL=
# NEXT_PUBLIC_LS_LIFETIME=
